# Hygraph
HYGRAPH_ENDPOINT=https://your-region.cdn.hygraph.com/content/your-project-id/master
HYGRAPH_DRAFT_ENDPOINT=https://api-your-region.hygraph.com/v2/your-project-id/master
HYGRAPH_TOKEN=your-permanent-auth-token

# Required for live preview — create a PAT with DRAFT as default stage and Read on all models
# HYGRAPH_PREVIEW_TOKEN=your-preview-pat-with-draft-permissions

# Optional — if set, /api/preview requires ?secret= matching this value
# PREVIEW_SECRET=your-random-string

# Public env vars (exposed to the browser)
NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://your-region.cdn.hygraph.com/content/your-project-id/master

# Optional — ExchangeRate-API key for higher quotas (free open endpoint used if unset)
# https://www.exchangerate-api.com/
# EXCHANGERATE_API_KEY=your-api-key

# Optional — Airtable as a stand-in PIM (falls back to mock data if unset)
# https://airtable.com/create/tokens
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...
# AIRTABLE_PRICING_TABLE=Pricing
# AIRTABLE_DEPARTURES_TABLE=Departures
